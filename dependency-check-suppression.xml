<?xml version="1.0" encoding="UTF-8"?>
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">
    
    <!-- DOMPurify CVE-2025-26791 in Swagger UI - Low severity, requires specific conditions -->
    <suppress>
        <notes><![CDATA[
        CVE-2025-26791 affects DOMPurify in Swagger UI.
        This is a low-severity XSS vulnerability that requires specific conditions.
        Swagger UI is only used for API documentation in development/testing.
        ]]></notes>
        <packageUrl regex="true">^pkg:javascript/DOMPurify@.*$</packageUrl>
        <cve>CVE-2025-26791</cve>
    </suppress>
    
    <!-- Netty - CPE matches Netty server; embed/transport is client-side only. Review when patched versions available. -->
    <suppress until="2026-05-18Z">
        <notes><![CDATA[
        Netty transport is used as HTTP client by WebFlux/WebClient. CPE mapping may overmatch.
        Using netty-bom 4.1.131.Final. Review when newer patched versions are available.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/io\.netty/netty\-.*@.*$</packageUrl>
        <cve>CVE-2025-55163</cve>
        <cve>CVE-2025-58057</cve>
        <cve>CVE-2025-67735</cve>
        <cve>CVE-2025-58056</cve>
    </suppress>
    
    <!-- Log4j API - CVE-2025-68161. Using log4j-bom 2.25.0. -->
    <suppress until="2026-05-18Z">
        <notes><![CDATA[
        Log4j 2.25.0 via BOM override. CVE-2025-68161 may be mitigated or require further assessment.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/org\.apache\.logging\.log4j/log4j\-api@.*$</packageUrl>
        <cve>CVE-2025-68161</cve>
    </suppress>
    
