        <notes><![CDATA[
        Tomcat embed (core, websocket) comes from Spring Boot 3.4.13 BOM. Upgrade Spring Boot when patched versions available.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/org\.apache\.tomcat\.embed/tomcat\-embed\-.*@.*$</packageUrl>
        <cve>CVE-2025-24813</cve>
        <cve>CVE-2025-31651</cve>
        <cve>CVE-2025-55754</cve>
        <cve>CVE-2025-49124</cve>
        <cve>CVE-2025-31650</cve>
        <cve>CVE-2025-48988</cve>
        <cve>CVE-2025-48989</cve>
        <cve>CVE-2025-49125</cve>
        <cve>CVE-2025-52520</cve>
        <cve>CVE-2025-53506</cve>
        <cve>CVE-2025-55752</cve>
        <cve>CVE-2025-46701</cve>
        <cve>CVE-2025-55668</cve>
        <cve>CVE-2025-61795</cve>
    </suppress>
    
    <!-- Quartz 2.3.2 - CVE-2023-39017 is disputed. No fix available (2.3.2 is the latest release).
         The Quartz team considers deserialization of job data an expected feature, not a vulnerability.
         Spring Boot controls serialization configuration, mitigating the risk. -->
    <suppress>
        <notes><![CDATA[
        CVE-2023-39017 (CVSS 9.8) is disputed by the Quartz project maintainers.
        Quartz 2.3.2 is the latest available version; no patched release exists.
        The vulnerability requires an attacker to control serialized job data,
        which is mitigated by Spring Boot's managed Quartz configuration.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/org\.quartz-scheduler/quartz@.*$</packageUrl>
        <cve>CVE-2023-39017</cve>
    </suppress>
    
    <!-- commons-jxpath 1.3 - transitive from Eureka client. Project is abandoned with no maintained fork. -->
    <suppress>
        <notes><![CDATA[
        commons-jxpath 1.3 is a transitive dependency from Netflix Eureka client.
        The Apache Commons JXPath project is retired with no maintained replacement.
        These CVEs relate to DoS via crafted XPath expressions; Eureka does not expose
        JXPath to untrusted input.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/commons-jxpath/commons-jxpath@.*$</packageUrl>
        <cve>CVE-2022-40159</cve>
        <cve>CVE-2022-40160</cve>
    </suppress>
    
    <!-- commons-configuration 1.10 - transitive from Eureka client. -->
    <suppress until="2026-05-18Z">
        <notes><![CDATA[
        commons-configuration 1.10 is a transitive dependency from Netflix Eureka client.
        Migration to commons-configuration2 (2.x) requires upstream changes in Eureka.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/commons-configuration/commons-configuration@.*$</packageUrl>
        <cve>CVE-2025-46392</cve>
    </suppress>
</suppressions>
